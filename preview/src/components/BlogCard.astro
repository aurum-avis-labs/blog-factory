---
import { getReadingTime } from "@/lib/utils";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  post: CollectionEntry<"blog">;
  brand: string;
  lang: string;
}

const { post, brand, lang } = Astro.props;

// Strip brand/lang prefix from ID to get slug
// ID format: {brand}/{lang}/slug.mdx
const parts = post.id.split("/");
const slug = parts.slice(2).join("/").replace(/\.mdx?$/, "");
const postUrl = `/${brand}/${lang}/blog/${slug}`;

const readTime = getReadingTime(post.body || "");

const formattedDate = post.data.pubDate.toLocaleDateString(
  lang === "en"
    ? "en-US"
    : lang === "de"
      ? "de-DE"
      : lang === "fr"
        ? "fr-FR"
        : "it-IT",
  { year: "numeric", month: "short", day: "numeric" }
);

const category =
  post.data.tags && post.data.tags.length > 0 ? post.data.tags[0] : null;

const getInitials = (name: string) =>
  name
    .split(" ")
    .map((p) => p[0])
    .join("")
    .toUpperCase()
    .slice(0, 2);
---

<a
  href={postUrl}
  class="group flex flex-col w-full h-full bg-transparent hover:bg-transparent transition-all duration-300"
>
  <div class="relative overflow-hidden rounded-2xl aspect-[4/3] mb-4">
    {
      post.data.image ? (
        <Image
          src={post.data.image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-muted/30 flex items-center justify-center group-hover:bg-muted/50 transition-colors">
          <span class="text-muted-foreground/50 text-4xl font-bold">Blog</span>
        </div>
      )
    }
    {
      category && (
        <div class="absolute top-4 left-4 z-10">
          <span class="bg-background/80 backdrop-blur-xs text-foreground px-3 py-1 text-xs font-medium rounded-full shadow-xs">
            {category}
          </span>
        </div>
      )
    }
  </div>

  <div class="flex flex-col flex-1 pt-1">
    <div
      class="flex items-center gap-3 text-sm text-muted-foreground mb-3 font-medium"
    >
      <span>{formattedDate}</span>
      <span>&bull;</span>
      <span>{readTime}</span>
      <span>&bull;</span>
      <span class="uppercase text-xs">{lang}</span>
    </div>

    <h3
      class="text-2xl font-bold mb-3 group-hover:text-primary transition-colors line-clamp-2 leading-snug"
    >
      {post.data.title}
    </h3>

    <p class="text-muted-foreground text-base line-clamp-2 mb-5 leading-relaxed">
      {post.data.description}
    </p>

    {
      post.data.author && (
        <div class="mt-auto flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary ring-2 ring-background">
            {getInitials(post.data.author)}
          </div>
          <span class="text-sm font-semibold text-foreground">
            {post.data.author}
          </span>
        </div>
      )
    }
  </div>
</a>
