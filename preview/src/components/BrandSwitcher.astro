---
import { brands } from "@/lib/brands";

interface Props {
  currentBrand?: string;
}

const { currentBrand } = Astro.props;
---

<nav class="sticky top-0 z-50 bg-background/95 backdrop-blur-sm border-b border-border">
  <div class="container mx-auto px-4 flex items-center gap-6 h-14">
    <a href="/" class="text-sm font-bold text-foreground shrink-0">
      Blog Factory
    </a>
    <div class="flex items-center gap-1 overflow-x-auto">
      {brands.map((brand) => (
        <a
          href={`/${brand.id}/blog`}
          class:list={[
            "px-3 py-1.5 rounded-full text-xs font-medium transition-colors whitespace-nowrap",
            currentBrand === brand.id
              ? "bg-primary text-primary-foreground"
              : "text-muted-foreground hover:text-foreground hover:bg-muted",
          ]}
        >
          {brand.displayName}
        </a>
      ))}
    </div>
  </div>
</nav>
