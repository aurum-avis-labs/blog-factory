---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { brands } from "@/lib/brands";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

// Count posts per brand
const postCounts: Record<string, number> = {};
for (const brand of brands) {
  postCounts[brand.id] = allPosts.filter((p) =>
    p.id.startsWith(brand.id + "/")
  ).length;
}
---

<BaseLayout title="Blog Factory - Brand Selector">
  <main class="container mx-auto px-4 py-16 max-w-5xl">
    <div class="mb-12">
      <h1 class="text-4xl font-bold mb-4">Blog Factory</h1>
      <p class="text-muted-foreground text-lg">
        Select a brand to preview its blog content.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        brands.map((brand) => (
          <a
            href={`/${brand.id}/blog`}
            class="group p-6 rounded-2xl border border-border hover:border-primary/50 hover:bg-muted/30 transition-all duration-300"
          >
            <h2 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">
              {brand.displayName}
            </h2>
            <p class="text-sm text-muted-foreground mb-4">{brand.domain}</p>
            <div class="flex items-center gap-4 text-xs text-muted-foreground">
              <span class="px-2 py-1 rounded-full bg-muted">
                {postCounts[brand.id] || 0} posts
              </span>
              <span class="px-2 py-1 rounded-full bg-muted">
                {brand.languages.join(", ")}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>
