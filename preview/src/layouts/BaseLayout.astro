---
import "@/styles/global.css";
import BrandSwitcher from "@/components/BrandSwitcher.astro";

interface Props {
  title: string;
  description?: string;
  brand?: string;
}

const { title, description = "Blog Factory Preview", brand } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <BrandSwitcher currentBrand={brand} />
    <slot />
  </body>
</html>
