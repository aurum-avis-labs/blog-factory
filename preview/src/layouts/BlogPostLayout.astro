---
import BaseLayout from "./BaseLayout.astro";
import { getReadingTime } from "@/lib/utils";
import type { CollectionEntry } from "astro:content";
import { ArrowLeft, Clock, Calendar } from "lucide-react";

interface Props {
  post: CollectionEntry<"blog">;
  brand: string;
  lang: string;
}

const { post, brand, lang } = Astro.props;

const readTime = getReadingTime(post.body || "");

const formattedDate = post.data.pubDate.toLocaleDateString(
  lang === "en"
    ? "en-US"
    : lang === "de"
      ? "de-DE"
      : lang === "fr"
        ? "fr-FR"
        : "it-IT",
  { year: "numeric", month: "long", day: "numeric" }
);

const getInitials = (name: string) =>
  name
    .split(" ")
    .map((p) => p[0])
    .join("")
    .toUpperCase()
    .slice(0, 2);

const category =
  post.data.tags && post.data.tags.length > 0 ? post.data.tags[0] : null;
---

<BaseLayout
  title={`${post.data.title} | ${brand}`}
  description={post.data.description}
  brand={brand}
>
  <article class="min-h-screen bg-background">
    <!-- Back Button -->
    <div class="container mx-auto px-4 pt-6">
      <a
        href={`/${brand}/blog`}
        class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors duration-300 group"
      >
        <span
          class="w-8 h-8 rounded-full bg-muted/50 flex items-center justify-center group-hover:bg-muted transition-colors"
        >
          <ArrowLeft className="w-4 h-4" />
        </span>
        <span class="font-medium">All Articles</span>
      </a>
    </div>

    <!-- Hero Section -->
    <header class="container mx-auto px-4 pt-8 pb-12 max-w-4xl">
      {
        category && (
          <div class="mb-6">
            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase bg-primary/10 text-primary">
              {category}
            </span>
          </div>
        )
      }

      <h1
        class="text-3xl sm:text-4xl md:text-5xl font-bold leading-[1.15] tracking-tight text-foreground mb-8"
      >
        {post.data.title}
      </h1>

      <div
        class="flex flex-wrap items-center gap-6 pb-8 border-b border-border/50"
      >
        {
          post.data.author && (
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-sm font-bold text-primary ring-2 ring-background shadow-sm">
                {getInitials(post.data.author)}
              </div>
              <div class="flex flex-col">
                <span class="text-sm font-semibold text-foreground">
                  {post.data.author}
                </span>
                <span class="text-xs text-muted-foreground">Author</span>
              </div>
            </div>
          )
        }

        {
          post.data.author && (
            <div class="hidden sm:block w-px h-10 bg-border/50" />
          )
        }

        <div class="flex items-center gap-4 text-sm text-muted-foreground">
          <div class="flex items-center gap-2">
            <Calendar className="w-4 h-4 opacity-60" />
            <time
              datetime={post.data.pubDate.toISOString()}
              class="font-medium"
            >
              {formattedDate}
            </time>
          </div>
          <div class="flex items-center gap-2">
            <Clock className="w-4 h-4 opacity-60" />
            <span class="font-medium">{readTime}</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Article Content -->
    <main class="container mx-auto px-4 max-w-3xl">
      <div class="prose-editorial">
        <slot />
      </div>
    </main>

    <!-- Tags -->
    {
      post.data.tags && post.data.tags.length > 0 && (
        <div class="container mx-auto px-4 max-w-3xl mt-16">
          <div class="flex flex-wrap items-center gap-3 pt-8 border-t border-border/50">
            {post.data.tags.map((tag: string) => (
              <span class="px-4 py-2 rounded-full text-sm font-medium bg-muted/50 text-muted-foreground">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )
    }

    <!-- Divider -->
    <div class="container mx-auto px-4 max-w-3xl my-20">
      <div class="flex items-center justify-center gap-4">
        <div
          class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"
        >
        </div>
        <div class="w-2 h-2 rounded-full bg-primary/30"></div>
        <div
          class="h-px flex-1 bg-gradient-to-r from-transparent via-border to-transparent"
        >
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
